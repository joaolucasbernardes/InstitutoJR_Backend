{
    "version": 2,
    "builds": [
      {
        "src": "package.json",
        "use": "@vercel/node",
        "config": {
          "includeFiles": [
            "config/**",
            "public/**",
            "src/**",
            "data/**",
            "api/**",
            ".env"
          ]
        }
      }
    ],
    "routes": [
      { "src": "/(.*)", "dest": "/index.js" }
    ]
  }
  